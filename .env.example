# Gateway configuration. Copy to .env and adjust.

# --- core ---
DATABASE_URL=postgres://shellwarden:shellwarden@localhost:5432/shellwarden?sslmode=disable
JWT_SECRET=change-me-to-a-random-64-char-string-change-me-to-a-random-64char
GATEWAY_PORT=8080
RECORDING_PATH=./recordings
STATIC_PATH=./static
AGENTS_PATH=./agents

# --- RDP (Guacamole sidecar) ---
GUACD_HOST=localhost
GUACD_PORT=4822

# --- bulk exec ---
BULK_TIMEOUT_SEC=30

# --- secrets encryption at rest (defaults to JWT_SECRET if unset) ---
SECRET_KEY=change-me-to-a-separate-32+byte-encryption-key

# --- session policy ---
SESSION_IDLE_MIN=0      # disconnect after N idle minutes (0 = off)
SESSION_MAX_MIN=0       # hard cap on session length (0 = off)
JIT_REQUIRED=false      # require an approved JIT grant to open a session

# --- SSH certificate authority (credential-less access) ---
# If unset, the gateway auto-generates and persists a CA. Targets must trust it:
#   curl https://gateway/ca/pubkey >> (TrustedUserCAKeys file)
# SSH_CA_KEY=            # PEM private key (inline)
# SSH_CA_KEY_FILE=       # ...or path to it
SSH_CERT_TTL_MIN=5

# --- notifications / SIEM streaming ---
# WEBHOOK_URL=https://hooks.slack.com/...      # security/ops events
# SIEM_WEBHOOK_URL=https://siem.internal/ingest # every audit event streamed

# --- OIDC / SSO (enabled when issuer + client id are set) ---
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URL=https://gateway.internal:8080/api/auth/oidc/callback
